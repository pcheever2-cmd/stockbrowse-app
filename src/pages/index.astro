---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Compass Score | Find Quality Stocks with Confidence">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-emerald-600 to-emerald-700 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Stop Guessing. Start Investing with Confidence.
      </h1>
      <p class="text-xl md:text-2xl text-emerald-100 mb-8 max-w-2xl mx-auto">
        The Compass Score rates every stock from 0-100 based on 30 years of research.
        Find quality companies without needing a finance degree.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/tool" class="bg-white text-emerald-700 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-emerald-50 transition">
          Look Up Any Stock
        </a>
        <a href="/how-it-works" class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition">
          How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">
        Tired of Being Told to "Do Your Research"?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">😵</span>
          </div>
          <h3 class="font-semibold mb-2">Information Overload</h3>
          <p class="text-slate-600">Hundreds of metrics, ratios, and charts. Where do you even start?</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">💸</span>
          </div>
          <h3 class="font-semibold mb-2">Expensive Tools</h3>
          <p class="text-slate-600">Premium platforms cost $30-50/month and assume you already know what you're doing.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🎰</span>
          </div>
          <h3 class="font-semibold mb-2">Meme Stock Madness</h3>
          <p class="text-slate-600">Social media pushes hype over substance. One bad pick and your savings are gone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">
        One Score. Backed by Data.
      </h2>
      <p class="text-xl text-slate-600 text-center mb-12 max-w-2xl mx-auto">
        The Compass Score combines the metrics that actually matter into a single 0-100 rating.
      </p>

      <div class="bg-white rounded-2xl shadow-lg p-8 mb-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-bold mb-4">What the Score Tells You</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-emerald-500 mt-1">✓</span>
                <span><strong>85-100 (Grade A):</strong> High quality. Strong fundamentals, low risk.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-emerald-500 mt-1">✓</span>
                <span><strong>60-84 (Grade B):</strong> Above average. Good quality, moderate risk.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-slate-400 mt-1">—</span>
                <span><strong>40-59 (Grade C):</strong> Neutral. Average characteristics.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">⚠</span>
                <span><strong>20-39 (Grade D):</strong> Speculative. Weak fundamentals or high volatility.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">✗</span>
                <span><strong>0-19 (Grade F):</strong> High risk. Poor quality metrics.</span>
              </li>
            </ul>
          </div>
          <div class="bg-slate-50 rounded-xl p-6">
            <h4 class="font-semibold text-center mb-4">Famous Stock Examples</h4>
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span>Apple (AAPL)</span>
                <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-sm font-semibold">99 - A</span>
              </div>
              <div class="flex justify-between items-center">
                <span>Microsoft (MSFT)</span>
                <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-sm font-semibold">89 - A</span>
              </div>
              <div class="flex justify-between items-center">
                <span>JPMorgan (JPM)</span>
                <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-semibold">68 - B</span>
              </div>
              <div class="flex justify-between items-center">
                <span>Tesla (TSLA)</span>
                <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-sm font-semibold">29 - D</span>
              </div>
              <div class="flex justify-between items-center">
                <span>Super Micro (SMCI)</span>
                <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-semibold">11 - F</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Credibility -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Built on Real Research</h2>
      <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto">
        Not another hype tool. The Compass Score is based on academic finance principles and tested across 30 years of market data.
      </p>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-slate-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-emerald-600 mb-2">30</div>
          <div class="text-slate-600">Years of Data</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-emerald-600 mb-2">5,000+</div>
          <div class="text-slate-600">Stocks Scored</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-emerald-600 mb-2">+6%</div>
          <div class="text-slate-600">Annual Spread*</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-6">
          <div class="text-3xl font-bold text-emerald-600 mb-2">0</div>
          <div class="text-slate-600">Hype Factors</div>
        </div>
      </div>
      <p class="text-sm text-slate-500 mt-6">*Top-quintile vs bottom-quintile annual return spread in out-of-sample testing (2020-2026). Past performance does not guarantee future results.</p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-emerald-600 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Invest Smarter?</h2>
      <p class="text-xl text-emerald-100 mb-8">
        Look up any stock and see its Compass Score instantly.
      </p>
      <a href="/tool" class="inline-block bg-white text-emerald-700 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-emerald-50 transition">
        Try the Compass Score Tool
      </a>
    </div>
  </section>

  <!-- Email Capture -->
  <section class="py-16 bg-slate-900 text-white">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Get Weekly Stock Insights</h2>
      <p class="text-slate-400 mb-6">
        Join thousands of investors learning to pick quality stocks. No spam, unsubscribe anytime.
      </p>
      <form class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 rounded-lg text-slate-900 placeholder:text-slate-500"
          required
        />
        <button type="submit" class="bg-emerald-500 hover:bg-emerald-400 px-6 py-3 rounded-lg font-semibold transition">
          Subscribe
        </button>
      </form>
    </div>
  </section>
</Layout>
