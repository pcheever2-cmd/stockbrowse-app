---
import Layout from '../layouts/Layout.astro';
import { getTopStocks, getGradeColor, formatPrice, getNormalizedIndustry, stocks, getStockBySymbol } from '../data/stocks';

const topStocks = getTopStocks(8);
const aGradeCount = stocks.filter(s => s.grade === 'A').length;
const bGradeCount = stocks.filter(s => s.grade === 'B').length;

// Famous stock examples - pulled dynamically (showing A-F range)
const famousSymbols = ['AAPL', 'NVDA', 'GOOGL', 'META', 'PLTR', 'AMD', 'COIN', 'SMCI'];
const famousStocks = famousSymbols.map(sym => getStockBySymbol(sym)).filter(Boolean);
---

<Layout title="Compass Score | Find Quality Stocks with Confidence">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-[#22D3EE] to-emerald-700 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Stop Guessing. Start Investing with Confidence.
      </h1>
      <p class="text-xl md:text-2xl text-emerald-100 mb-8 max-w-2xl mx-auto">
        The Compass Score rates every stock from 0-100 based on 30 years of research.
        Find quality companies without needing a finance degree.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/browse/all" class="bg-[#161B24] text-emerald-700 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-emerald-50 transition">
          Browse Quality Stocks
        </a>
        <a href="/tool" class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-[#161B24]/10 transition">
          Look Up a Stock
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="py-8 bg-[#161B24] border-b border-[rgba(255,255,255,0.06)]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 text-center">
        <div>
          <div class="text-3xl font-bold text-[#22D3EE]">{stocks.length.toLocaleString()}+</div>
          <div class="text-sm text-[#CBD5E1]">Stocks Analyzed</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#22D3EE]">{aGradeCount}</div>
          <div class="text-sm text-[#CBD5E1]">Grade A Stocks</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#22D3EE]">{bGradeCount}</div>
          <div class="text-sm text-[#CBD5E1]">Grade B Stocks</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#22D3EE]">6</div>
          <div class="text-sm text-[#CBD5E1]">Quality Factors</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Free Forever Section -->
  <section class="py-12 bg-[#161B24]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-emerald-50 border-2 border-emerald-200 rounded-xl p-8">
        <h3 class="text-2xl font-bold mb-4 text-center">🎁 Free Forever</h3>
        <p class="text-slate-700 mb-6 text-center max-w-2xl mx-auto">
          Start browsing quality stocks today. No credit card required.
        </p>
        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div class="flex items-start gap-2">
            <span class="text-[#22D3EE] mt-1">✓</span>
            <span class="text-slate-700">Browse all 5,000+ stocks</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-[#22D3EE] mt-1">✓</span>
            <span class="text-slate-700">See letter grades (A-F) for every company</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-[#22D3EE] mt-1">✓</span>
            <span class="text-slate-700">10 full score lookups per day</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-[#22D3EE] mt-1">✓</span>
            <span class="text-slate-700">Filter by industry, budget, and goals</span>
          </div>
        </div>
        <p class="text-sm text-[#CBD5E1] text-center">
          Upgrade anytime for unlimited lookups and premium features.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Browse Cards -->
  <section class="py-12 bg-[#080A0F]">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Browse Quality Stocks</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/browse/growth" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">📈</div>
          <div class="font-semibold">Growth</div>
        </a>
        <a href="/browse/dividends" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">💰</div>
          <div class="font-semibold">Dividends</div>
        </a>
        <a href="/browse/low-risk" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">🛡️</div>
          <div class="font-semibold">Low-Risk</div>
        </a>
        <a href="/browse" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">🏭</div>
          <div class="font-semibold">By Industry</div>
        </a>
        <a href="/browse/under-10" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">💵</div>
          <div class="font-semibold">Under $10</div>
        </a>
        <a href="/browse/under-50" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">💸</div>
          <div class="font-semibold">Under $50</div>
        </a>
        <a href="/browse/under-100" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">💳</div>
          <div class="font-semibold">Under $100</div>
        </a>
        <a href="/browse/starter-500" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 text-center hover:shadow-lg hover:border-emerald-300 transition">
          <div class="text-3xl mb-2">🎯</div>
          <div class="font-semibold">Starter ($500)</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Top Rated Stocks -->
  <section class="py-16 bg-[#161B24]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-2">Top-Rated Stocks Right Now</h2>
        <p class="text-[#CBD5E1]">Highest quality companies based on the Compass Score</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        {topStocks.map(stock => {
          const colors = getGradeColor(stock.grade);
          return (
            <a href={`/stock/${stock.symbol.toLowerCase()}`}
               class="bg-[#080A0F] border border-[rgba(255,255,255,0.06)] rounded-xl p-5 hover:shadow-lg hover:border-emerald-300 transition">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-bold text-lg">{stock.symbol}</h3>
                  <p class="text-[#64748B] text-sm truncate max-w-[140px]">{stock.name}</p>
                </div>
                <div class={`px-3 py-1 rounded-full ${colors.bg} ${colors.text} font-bold`}>
                  {stock.compassScore}
                </div>
              </div>
              <div class="flex justify-between items-end">
                <div>
                  <div class="text-xl font-bold">{formatPrice(stock.price)}</div>
                  <div class="text-xs text-[#64748B]">{getNormalizedIndustry(stock.industry)}</div>
                </div>
                <div class={`text-sm font-semibold ${colors.text}`}>
                  Grade {stock.grade}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div class="text-center">
        <a href="/browse" class="inline-block bg-[#22D3EE] hover:bg-[#06B6D4] text-white px-8 py-3 rounded-lg font-semibold transition">
          View All {stocks.length.toLocaleString()}+ Stocks
        </a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-16 bg-[#080A0F]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">
        Tired of Being Told to "Do Your Research"?
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">😵</span>
          </div>
          <h3 class="font-semibold mb-2">Information Overload</h3>
          <p class="text-[#CBD5E1]">Hundreds of metrics, ratios, and charts. Where do you even start?</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">💸</span>
          </div>
          <h3 class="font-semibold mb-2">Expensive Tools</h3>
          <p class="text-[#CBD5E1]">Premium platforms cost $30-50/month and assume you already know what you're doing.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🎰</span>
          </div>
          <h3 class="font-semibold mb-2">Meme Stock Madness</h3>
          <p class="text-[#CBD5E1]">Social media pushes hype over substance. One bad pick and your savings are gone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="py-16 bg-[#161B24]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">
        One Score. Backed by Data.
      </h2>
      <p class="text-xl text-[#CBD5E1] text-center mb-12 max-w-2xl mx-auto">
        The Compass Score combines the metrics that actually matter into a single 0-100 rating.
      </p>

      <div class="bg-[#080A0F] rounded-2xl p-8 mb-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-bold mb-4">What the Score Tells You</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-[#22D3EE] mt-1">✓</span>
                <span><strong>85-100 (Grade A):</strong> High quality. Strong fundamentals, low risk.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#22D3EE] mt-1">✓</span>
                <span><strong>60-84 (Grade B):</strong> Above average. Good quality, moderate risk.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-slate-400 mt-1">—</span>
                <span><strong>40-59 (Grade C):</strong> Neutral. Average characteristics.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">⚠</span>
                <span><strong>20-39 (Grade D):</strong> Speculative. Weak fundamentals or high volatility.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-500 mt-1">✗</span>
                <span><strong>0-19 (Grade F):</strong> High risk. Poor quality metrics.</span>
              </li>
            </ul>
          </div>
          <div class="bg-[#161B24] rounded-xl p-6 border border-[rgba(255,255,255,0.06)]">
            <h4 class="font-semibold text-center mb-2">Famous Stock Examples</h4>
            <p class="text-xs text-[#64748B] text-center mb-4">From high-quality giants to speculative plays</p>
            <div class="space-y-3">
              {famousStocks.map(stock => {
                const colors = getGradeColor(stock.grade);
                return (
                  <a href={`/stock/${stock.symbol.toLowerCase()}`} class="flex justify-between items-center hover:bg-[#080A0F] p-2 rounded-lg transition">
                    <span>{stock.name} ({stock.symbol})</span>
                    <span class={`${colors.bg} ${colors.text} px-3 py-1 rounded-full text-sm font-semibold`}>{stock.compassScore} - {stock.grade}</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-[#161B24]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🔍</span>
          </div>
          <h3 class="font-semibold text-xl mb-2">1. Browse by Your Goals</h3>
          <p class="text-[#CBD5E1]">Filter by industry, budget, dividends, or risk level. No finance jargon required.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">📊</span>
          </div>
          <h3 class="font-semibold text-xl mb-2">2. See the Compass Score</h3>
          <p class="text-[#CBD5E1]">Every stock rated 0-100 based on profitability, cash flow, and stability. Backed by 30 years of data.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">✅</span>
          </div>
          <h3 class="font-semibold text-xl mb-2">3. Read Plain English</h3>
          <p class="text-[#CBD5E1]">No spreadsheets. Get a simple assessment: is this a quality company?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Credibility -->
  <section class="py-16 bg-[#080A0F]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Built on Real Research</h2>
      <p class="text-xl text-[#CBD5E1] mb-12 max-w-2xl mx-auto">
        Not another hype tool. The Compass Score is based on academic finance principles and tested across 30 years of market data.
      </p>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-[#161B24] rounded-xl p-6 border border-[rgba(255,255,255,0.06)]">
          <div class="text-3xl font-bold text-[#22D3EE] mb-2">935,000+</div>
          <div class="text-[#CBD5E1]">Stock Observations</div>
        </div>
        <div class="bg-[#161B24] rounded-xl p-6 border border-[rgba(255,255,255,0.06)]">
          <div class="text-3xl font-bold text-[#22D3EE] mb-2">30</div>
          <div class="text-[#CBD5E1]">Years Backtested</div>
        </div>
        <div class="bg-[#161B24] rounded-xl p-6 border border-[rgba(255,255,255,0.06)]">
          <div class="text-3xl font-bold text-[#22D3EE] mb-2">+6.79%</div>
          <div class="text-[#CBD5E1]">OOS Annual Spread*</div>
        </div>
        <div class="bg-[#161B24] rounded-xl p-6 border border-[rgba(255,255,255,0.06)]">
          <div class="text-3xl font-bold text-[#22D3EE] mb-2">All 4</div>
          <div class="text-[#CBD5E1]">Market Cap Segments</div>
        </div>
      </div>
      <p class="text-sm text-[#64748B] mt-6">
        *Out-of-sample Q5-Q1 spread (2020-2026). Past performance does not guarantee future results.
        <a href="/methodology" class="text-[#22D3EE] hover:underline">Read the research →</a>
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-[#22D3EE] text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Invest Smarter?</h2>
      <p class="text-xl text-emerald-100 mb-8">
        Look up any stock and see its Compass Score instantly.
      </p>

      <!-- Pricing Tier Preview -->
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-8">
        <div class="bg-[#161B24] text-slate-100 border border-[rgba(255,255,255,0.06)] rounded-xl p-6">
          <h3 class="font-bold text-xl mb-2">Free</h3>
          <div class="text-3xl font-bold mb-4">$0</div>
          <ul class="text-sm space-y-2 text-left text-[#CBD5E1]">
            <li>✓ Browse all stocks</li>
            <li>✓ Letter grades (A-F)</li>
            <li>✓ 10 lookups/day</li>
          </ul>
        </div>
        <div class="bg-[#161B24] text-slate-100 border-2 border-[#06B6D4] rounded-xl p-6 relative shadow-lg">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#22D3EE] text-white px-3 py-1 rounded-full text-xs font-semibold">
            MOST POPULAR
          </div>
          <h3 class="font-bold text-xl mb-2">Compass Weekly</h3>
          <div class="text-3xl font-bold mb-4">$5<span class="text-sm text-[#64748B]">/mo</span></div>
          <ul class="text-sm space-y-2 text-left text-[#CBD5E1]">
            <li>✓ Everything in Free</li>
            <li>✓ Unlimited lookups</li>
            <li>✓ Weekly top stocks</li>
            <li>✓ Market insights</li>
          </ul>
        </div>
        <div class="bg-[#161B24]/90 text-slate-100 border border-[rgba(255,255,255,0.06)] rounded-xl p-6 opacity-90">
          <h3 class="font-bold text-xl mb-2">Premium</h3>
          <div class="text-3xl font-bold mb-4">$15<span class="text-sm text-[#64748B]">/mo</span></div>
          <ul class="text-sm space-y-2 text-left text-[#CBD5E1]">
            <li>✓ Everything in Weekly</li>
            <li>✓ Growth Score (Moonshot)</li>
            <li>✓ Momentum Score</li>
            <li>✓ Advanced filters</li>
          </ul>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/tool" class="inline-block bg-[#161B24] text-emerald-700 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-emerald-50 transition">
          Try the Score Lookup Tool
        </a>
        <a href="/pricing" class="inline-block border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-[#161B24]/10 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Email Capture -->
  <section class="py-16 bg-slate-900 text-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Compass Weekly Newsletter</h2>
      <p class="text-slate-300 mb-6">
        Get the top-scoring stocks each week, delivered to your inbox. Plus educational content on stock fundamentals.
      </p>
      <div class="bg-slate-800 rounded-lg p-6 mb-6 text-left">
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-[#06B6D4] mt-1">✓</span>
            <span class="text-slate-300">Top 10 quality stocks updated weekly</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#06B6D4] mt-1">✓</span>
            <span class="text-slate-300">Plain English market insights</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[#06B6D4] mt-1">✓</span>
            <span class="text-slate-300">Learn to pick stocks yourself</span>
          </li>
        </ul>
      </div>
      <form class="flex flex-col sm:flex-row gap-3 mb-4">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 rounded-lg text-slate-100 placeholder:text-[#64748B]"
          required
        />
        <button type="submit" class="bg-[#22D3EE] hover:bg-[#06B6D4] px-6 py-3 rounded-lg font-semibold transition">
          Start Free Trial
        </button>
      </form>
      <p class="text-sm text-slate-400">
        $5/month after 7-day free trial. Cancel anytime.
      </p>
      <p class="text-xs text-[#64748B] mt-4">
        <a href="/insights" class="text-[#06B6D4] hover:underline">Learn more about Compass Weekly →</a>
      </p>
    </div>
  </section>

  <!-- JSON-LD Structured Data for AI Discoverability -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Compass Score",
    "applicationCategory": "FinanceApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Stock quality scoring system based on 30 years of academic research. Browse 5,000+ stocks with free letter grades (A-F).",
    "featureList": [
      "Browse 5000+ stocks by industry and budget",
      "Letter grades (A-F) for every company",
      "Research-backed quality scores",
      "Plain English stock assessments"
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "What is the Compass Score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Compass Score rates stocks from 0-100 based on profitability, cash flow, and stability. Scores are based on 30 years of backtested data across 935,000+ stock observations."
      }
    }, {
      "@type": "Question",
      "name": "Is the Compass Score free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can browse all 5,000+ stocks and see letter grades (A-F) for free. Free users get 10 detailed score lookups per day."
      }
    }]
  }
  </script>
</Layout>
