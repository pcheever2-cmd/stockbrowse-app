          { icon: '🌍', title: 'Diversify Across Sectors', explanation: 'Don\'t put all your eggs in one basket. Spread across different industries to reduce risk.' },
          { icon: '📈', title: 'Balance Growth and Stability', explanation: 'Mix some growth-oriented picks with stable, dividend-paying companies. This gives you upside without too much risk.' },
        ],
      };
      return metrics[profileKey] || metrics.steady;
    }

    function getProfileLinks(profileKey) {
      const links = {
        longGame: [
          { icon: '🛡️', title: 'Browse Low-Risk Quality Stocks', desc: 'A and B rated stocks sorted by quality', href: '/browse/low-risk' },
          { icon: '💰', title: 'Browse Dividend Stocks', desc: 'Quality companies in dividend-paying sectors', href: '/browse/dividends' },
          { icon: '📖', title: 'How the Compass Score Works', desc: 'Understand the 6 quality factors behind the ratings', href: '/how-it-works' },
        ],
        income: [
          { icon: '💰', title: 'Browse Dividend Stocks', desc: 'Quality companies in dividend-paying sectors', href: '/browse/dividends' },
          { icon: '🛡️', title: 'Browse Low-Risk Quality', desc: 'Stable, high-quality companies', href: '/browse/low-risk' },
          { icon: '📖', title: 'How the Compass Score Works', desc: 'Learn what makes a quality dividend stock', href: '/how-it-works' },
        ],
        growth: [
          { icon: '🚀', title: 'Browse Growth Stocks', desc: 'Quality growth companies in tech, healthcare, and more', href: '/browse/growth' },
          { icon: '📖', title: 'Moonshot Score Methodology', desc: 'How we identify quality growth stocks', href: '/moonshot-methodology' },
          { icon: '🔍', title: 'Browse All Stocks', desc: 'Use advanced filters to find your own picks', href: '/browse/all' },
        ],
        bold: [
          { icon: '🚀', title: 'Browse Growth Stocks', desc: 'The highest-quality growth companies', href: '/browse/growth' },
          { icon: '📖', title: 'Moonshot Score Methodology', desc: 'Understand how we measure growth momentum', href: '/moonshot-methodology' },
          { icon: '🔍', title: 'Browse All Stocks', desc: 'Apply your own filters across 4,500+ stocks', href: '/browse/all' },
        ],
        smart: [
          { icon: '🔍', title: 'Browse All Stocks', desc: 'Filter by "Undervalued" in the Technical Valuation filter', href: '/browse/all?valuation=Undervalued' },
          { icon: '📖', title: 'Valuation Score Methodology', desc: 'How we identify undervalued stocks using SMA200', href: '/valuation-methodology' },
          { icon: '📊', title: 'How the Compass Score Works', desc: 'Combine valuation with quality for better picks', href: '/how-it-works' },
        ],
        steady: [
          { icon: '🔍', title: 'Browse All Stocks', desc: 'Explore 4,500+ stocks with quality and valuation filters', href: '/browse/all' },
          { icon: '📖', title: 'How the Compass Score Works', desc: 'Understand the quality factors behind the ratings', href: '/how-it-works' },
          { icon: '🚀', title: 'Browse Growth Stocks', desc: 'See the highest-quality growth companies', href: '/browse/growth' },
        ],
      };
      return links[profileKey] || links.steady;
    }

    // ── Retake ──
    document.getElementById('retake-btn').addEventListener('click', () => {
      localStorage.removeItem('quizProfile');
      answers.experience = null; answers.goal = null; answers.risk = null;
      answers.industries = []; answers.approach = null; answers.barrier = null;
      resultsScreen.classList.add('hidden');
      document.getElementById('welcome-back').classList.add('hidden');
      introScreen.classList.remove('hidden');
      currentStep = -1;
      // Reset all card highlights
      document.querySelectorAll('.answer-card').forEach(c => {
        c.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
        c.classList.add('border-[rgba(255,255,255,0.06)]');
      });
      pillsContainer.querySelectorAll('.industry-pill').forEach(p => {
        p.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10', 'text-[#22D3EE]');
      });
      escapeBtn.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
      escapeBtn.classList.add('border-[rgba(255,255,255,0.12)]');
      continueBtn.disabled = true;
      continueBtn.textContent = 'Continue';
      const url = new URL(window.location);
      url.searchParams.delete('profile');
      history.replaceState(null, '', url);
    });

    // ── Share ──
    document.getElementById('share-btn').addEventListener('click', () => {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('share-btn');
        const orig = btn.innerHTML;
        btn.textContent = 'Link copied!';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
      });
    });
  </script>
</Layout>
