---
import Layout from '../layouts/Layout.astro';
import { stocks, getNormalizedIndustry, formatPrice, formatMarketCap, getGradeColor } from '../data/stocks';

// Pre-compute stock pools (trimmed to card fields only)
function trimStock(s: any) {
  return {
    symbol: s.symbol, name: s.name, price: s.price,
    compassScore: s.compassScore, grade: s.grade,
    industry: getNormalizedIndustry(s.industry), sector: s.sector,
    marketCap: s.marketCap, moonshotScore: s.moonshotScore,
    moonshotGrade: s.moonshotGrade, valuationRating: s.valuationRating,
    isGolden: s.isGolden, epsGrowth: s.epsGrowth,
    volatility: s.factorValues?.volatility ?? null,
  };
}

const gradeOrder = { A: 5, B: 4, C: 3, D: 2, F: 1 };
const gradeVal = (g: string | null) => gradeOrder[g as keyof typeof gradeOrder] ?? 0;

// Pool: The Long Game - grade A/B, low volatility, sorted by compass
const longGamePool = stocks
  .filter(s => (s.grade === 'A' || s.grade === 'B') && (s.factorValues?.volatility ?? 100) < 35)
  .sort((a, b) => b.compassScore - a.compassScore)
  .slice(0, 30).map(trimStock);

// Pool: Income Builder - dividend sectors, grade B+
const dividendSectors = ['Utilities', 'Real Estate', 'Finance', 'Consumer', 'Energy'];
const incomePool = stocks
  .filter(s => dividendSectors.includes(getNormalizedIndustry(s.industry)) && gradeVal(s.grade) >= 4)
  .sort((a, b) => b.compassScore - a.compassScore)
  .slice(0, 30).map(trimStock);

// Pool: Growth Explorer - moonshotGrade A/B
const growthPool = stocks
  .filter(s => (s.moonshotGrade === 'A' || s.moonshotGrade === 'B') && gradeVal(s.grade) >= 3)
  .sort((a, b) => (b.moonshotScore ?? 0) - (a.moonshotScore ?? 0))
  .slice(0, 30).map(trimStock);

// Pool: Bold Investor - moonshotGrade A, high growth, grade C+ floor
const boldPool = stocks
  .filter(s => s.moonshotGrade === 'A' && gradeVal(s.grade) >= 3 && (s.epsGrowth ?? 0) > 15)
  .sort((a, b) => (b.moonshotScore ?? 0) - (a.moonshotScore ?? 0))
  .slice(0, 30).map(trimStock);

// Pool: Smart Shopper - undervalued, grade C+
const smartPool = stocks
  .filter(s => s.valuationRating === 'Undervalued' && gradeVal(s.grade) >= 3)
  .sort((a, b) => b.compassScore - a.compassScore)
  .slice(0, 30).map(trimStock);

// Pool: Steady Climber - isGolden preferred, grade B+
const steadyPool = stocks
  .filter(s => gradeVal(s.grade) >= 4)
  .sort((a, b) => {
    if (a.isGolden && !b.isGolden) return -1;
    if (!a.isGolden && b.isGolden) return 1;
    return b.compassScore - a.compassScore;
  })
  .slice(0, 30).map(trimStock);

const stockPools = { longGame: longGamePool, income: incomePool, growth: growthPool, bold: boldPool, smart: smartPool, steady: steadyPool };
---

