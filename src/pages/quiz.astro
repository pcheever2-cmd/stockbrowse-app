    const slidesTrack = document.getElementById('slides-track');
    const progressSegs = document.querySelectorAll('.progress-seg');

    // ── Check for returning user ──
    const savedProfile = localStorage.getItem('quizProfile');
    const urlProfile = new URLSearchParams(window.location.search).get('profile');
    if (urlProfile && profiles[urlProfile]) {
      showResults(urlProfile, true);
    } else if (savedProfile && profiles[savedProfile]) {
      showResults(savedProfile, true);
    }

    // ── Init: populate risk (randomized) and industry pills ──
    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    // Risk options
    const riskContainer = document.getElementById('risk-options');
    shuffle([...riskOptions]).forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'answer-card w-full text-left p-4 rounded-xl border border-[rgba(255,255,255,0.06)] bg-[#161B24] hover:border-[#22D3EE]/50 transition';
      btn.dataset.value = opt.value;
      btn.innerHTML = `<div class="font-semibold">${opt.label}</div>${opt.sub ? `<div class="text-sm text-[#64748B] mt-1">${opt.sub}</div>` : ''}`;
      riskContainer.appendChild(btn);
    });

    // Industry pills
    const pillsContainer = document.getElementById('industry-pills');
    industryData.forEach(ind => {
      const pill = document.createElement('button');
      pill.className = 'industry-pill px-4 py-2 rounded-full border border-[rgba(255,255,255,0.1)] bg-[#161B24] hover:border-[#22D3EE]/50 transition text-sm flex items-center gap-2';
      pill.dataset.industry = ind.id;
      pill.innerHTML = `<span>${ind.emoji}</span><span>${ind.label}</span>`;
      pill.title = ind.examples;
      pillsContainer.appendChild(pill);
    });

    // ── Navigation ──
    document.getElementById('start-btn').addEventListener('click', () => {
      introScreen.classList.add('hidden');
      quizContainer.classList.remove('hidden');
      goToStep(0);
    });

    document.getElementById('back-btn').addEventListener('click', () => {
      if (currentStep > 0) goToStep(currentStep - 1);
      else { quizContainer.classList.add('hidden'); introScreen.classList.remove('hidden'); currentStep = -1; }
    });

    function goToStep(step) {
      currentStep = step;
      slidesTrack.style.transform = `translateX(-${step * 100}%)`;
      progressSegs.forEach((seg, i) => {
        seg.style.backgroundColor = i <= step ? '#22D3EE' : '#1C222E';
      });
    }

    // ── Single-select answer cards ──
    document.querySelectorAll('.quiz-slide').forEach(slide => {
      const q = slide.dataset.q;
      if (q === 'industries') return; // handled separately
      slide.querySelectorAll('.answer-card').forEach(card => {
        card.addEventListener('click', () => {
          // Highlight
          slide.querySelectorAll('.answer-card').forEach(c => {
            c.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
            c.classList.add('border-[rgba(255,255,255,0.06)]');
          });
          card.classList.remove('border-[rgba(255,255,255,0.06)]');
          card.classList.add('border-[#22D3EE]', 'bg-[#22D3EE]/10');
          answers[q] = card.dataset.value;

          // Auto-advance after 400ms
          setTimeout(() => {
            if (currentStep < 5) goToStep(currentStep + 1);
            else computeAndShowResults();
          }, 400);
        });
      });
    });

    // ── Industry multi-select ──
    const continueBtn = document.getElementById('industry-continue');
    const escapeBtn = document.getElementById('industry-escape');

    pillsContainer.addEventListener('click', (e) => {
      const pill = e.target.closest('.industry-pill');
      if (!pill) return;
      escapeBtn.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
      escapeBtn.classList.add('border-[rgba(255,255,255,0.12)]');

      const ind = pill.dataset.industry;
      const idx = answers.industries.indexOf(ind);
      if (idx > -1) {
        answers.industries.splice(idx, 1);
        pill.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10', 'text-[#22D3EE]');
      } else if (answers.industries.length < 5) {
        answers.industries.push(ind);
        pill.classList.add('border-[#22D3EE]', 'bg-[#22D3EE]/10', 'text-[#22D3EE]');
      }
      updateContinueBtn();
    });

    escapeBtn.addEventListener('click', () => {
      answers.industries = [];
      pillsContainer.querySelectorAll('.industry-pill').forEach(p => {
        p.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10', 'text-[#22D3EE]');
      });
      escapeBtn.classList.remove('border-[rgba(255,255,255,0.12)]');
      escapeBtn.classList.add('border-[#22D3EE]', 'bg-[#22D3EE]/10');
      continueBtn.disabled = false;
      continueBtn.textContent = 'Continue - open to anything';
    });

    continueBtn.addEventListener('click', () => {
      if (!continueBtn.disabled) goToStep(currentStep + 1);
    });

    function updateContinueBtn() {
      const n = answers.industries.length;
      continueBtn.disabled = n === 0;
      continueBtn.textContent = n > 0 ? `Continue - ${n} selected` : 'Continue';
    }

    // ── Scoring ──
    function computeAndShowResults() {
      const scores = { longGame: 0, income: 0, growth: 0, bold: 0, smart: 0, steady: 0 };

      // Q1: Experience (mostly adjusts next-steps, slight scoring)
      if (answers.experience === 'new' || answers.experience === 'passive') {
        scores.longGame += 1; scores.steady += 1;
      }
      if (answers.experience === 'active') {
        scores.bold += 1; scores.smart += 1;
      }

      // Q2: Goal (primary driver)
      if (answers.goal === 'grow') { scores.growth += 3; scores.steady += 2; }
      if (answers.goal === 'income') { scores.income += 4; }
      if (answers.goal === 'protect') { scores.longGame += 4; scores.steady += 1; }
      if (answers.goal === 'moonshot') { scores.bold += 3; scores.growth += 2; }

      // Q3: Risk
      if (answers.risk === 'pull') { scores.longGame += 3; scores.income += 1; }
      if (answers.risk === 'stressed') { scores.longGame += 1; scores.steady += 2; scores.income += 1; }
      if (answers.risk === 'shrug') { scores.growth += 1; scores.steady += 1; scores.smart += 1; }
      if (answers.risk === 'buy') { scores.bold += 3; scores.smart += 1; }

      // Q4: Industries (light influence)
      // No direct scoring from industries - used for filtering stock results

      // Q5: Approach
      if (answers.approach === 'trusted') { scores.longGame += 2; scores.steady += 1; }
      if (answers.approach === 'underappreciated') { scores.smart += 4; }
      if (answers.approach === 'momentum') { scores.growth += 2; scores.bold += 2; }
      if (answers.approach === 'mixed') { scores.steady += 3; }

      // Q6: Barrier (slight nudges)
      if (answers.barrier === 'losing') { scores.longGame += 1; }
      if (answers.barrier === 'burned') { scores.longGame += 1; scores.steady += 1; }

      // Find winner
      let best = 'steady';
      let bestScore = -1;
      for (const [key, val] of Object.entries(scores)) {
        if (val > bestScore) { bestScore = val; best = key; }
      }

      localStorage.setItem('quizProfile', best);
      showResults(best, false);
    }

    // ── Render Results ──
    function showResults(profileKey, isReturning) {
      introScreen.classList.add('hidden');
      quizContainer.classList.add('hidden');
      resultsScreen.classList.remove('hidden');

      if (isReturning) {
        document.getElementById('welcome-back').classList.remove('hidden');
      }

      const profile = profiles[profileKey];

      // Badge
      const badge = document.getElementById('profile-badge');
      badge.className = `inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold ${profile.badgeBg}`;
      badge.textContent = `Your profile`;

      // Name & desc
      document.getElementById('profile-name').textContent = profile.name;
      document.getElementById('profile-desc').textContent = profile.desc;

      // Bullets
      const bulletsEl = document.getElementById('profile-bullets');
      bulletsEl.innerHTML = profile.bullets.map(b =>
        `<div class="flex items-start gap-2"><span class="text-[#22D3EE] mt-0.5">&#10003;</span><span class="text-[#CBD5E1] text-sm">${b}</span></div>`
      ).join('');

      // Stock cards
      const pool = pools[profile.pool] || pools.steady;
      let filtered = [...pool];

      // Filter by selected industries if any
      if (answers.industries && answers.industries.length > 0) {
        const industryFiltered = filtered.filter(s => answers.industries.includes(s.industry));
        if (industryFiltered.length >= 3) filtered = industryFiltered;
      }

      // How many cards: "no time" = 3, "ready" = 6, else 4
      let cardCount = 4;
      if (answers.barrier === 'time') cardCount = 3;
      else if (answers.barrier === 'ready') cardCount = 6;

      const picks = filtered.slice(0, cardCount);
      const cardsEl = document.getElementById('stock-cards');
      cardsEl.innerHTML = picks.map(s => {
        const gradeColors = { A: ['bg-[#22D3EE15]','text-[#22D3EE]'], B: ['bg-[#34D39915]','text-[#34D399]'], C: ['bg-[#94A3B815]','text-[#94A3B8]'], D: ['bg-[#FBBF2415]','text-[#FBBF24]'], F: ['bg-[#F8717115]','text-[#F87171]'] };
        const [gbg, gtxt] = gradeColors[s.grade] || gradeColors.C;
        const fmtPrice = s.price > 0 ? `$${s.price.toFixed(2)}` : 'N/A';
        const fmtCap = s.marketCap >= 1000 ? `$${(s.marketCap/1000).toFixed(1)}T` : s.marketCap >= 1 ? `$${s.marketCap.toFixed(1)}B` : `$${(s.marketCap*1000).toFixed(0)}M`;
        const whyFit = getWhyItFits(s, profileKey);
        return `<a href="/stock/${s.symbol.toLowerCase()}" class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-5 hover:border-[#22D3EE]/40 transition block">
          <div class="flex justify-between items-start mb-3">
            <div><h4 class="font-bold text-lg">${s.name}</h4><p class="text-[#64748B] text-sm">${s.symbol} · ${s.industry}</p></div>
            <div class="px-3 py-1 rounded-full ${gbg} ${gtxt} font-bold text-sm">${s.compassScore}</div>
          </div>
          <div class="flex justify-between items-end mb-3">
            <div><div class="text-2xl font-bold">${fmtPrice}</div><div class="text-sm text-[#64748B]">${fmtCap} cap</div></div>
            <div class="text-sm font-semibold ${gtxt}">Grade ${s.grade}</div>
          </div>
          <div class="text-xs text-[#64748B] border-t border-[rgba(255,255,255,0.06)] pt-2 mt-1">${whyFit}</div>
        </a>`;
      }).join('');

      // Update explore link
      document.getElementById('explore-btn').href = profile.exploreLink;

      // Next steps
      const nextEl = document.getElementById('next-steps-content');
      const exp = answers.experience || 'new';
      let steps = [];
      if (exp === 'new' || exp === 'passive') {
        steps = [
          'Start by learning about 1-2 of these companies. Tap a card to read their full profile.',
          'There\'s no rush. Understanding what you\'re investing in matters more than timing.',
          '<a href="/how-it-works" class="text-[#22D3EE] hover:underline">Learn how we score stocks</a> so you know what the numbers mean.',
        ];
      } else if (exp === 'some') {
        steps = [
          'Compare these with what you already own. Look for diversification across industries.',
          'Check the Compass Score breakdowns to see where each company is strong or weak.',
          '<a href="/browse/all" class="text-[#22D3EE] hover:underline">Browse all stocks</a> with filters to find more matches.',
        ];
      } else {
        steps = [
          'Explore the full browse page with quality and valuation filters applied.',
          'Use the Moonshot Score to identify growth momentum alongside quality.',
          '<a href="/browse/all" class="text-[#22D3EE] hover:underline">Advanced filters</a> · <a href="/moonshot-methodology" class="text-[#22D3EE] hover:underline">Moonshot methodology</a>',
        ];
      }
      nextEl.innerHTML = steps.map(s => `<p>${s}</p>`).join('');

      // Update URL without reload
      const url = new URL(window.location);
      url.searchParams.set('profile', profileKey);
      history.replaceState(null, '', url);
    }

    function getWhyItFits(stock, profileKey) {
      switch (profileKey) {
        case 'longGame': return `High quality score (${stock.compassScore}) with ${stock.volatility && stock.volatility < 35 ? 'low volatility' : 'stable fundamentals'}`;
        case 'income': return `Strong quality in a dividend-friendly sector (${stock.industry})`;
        case 'growth': return `Moonshot Grade ${stock.moonshotGrade || 'B'} — strong growth momentum`;
        case 'bold': return `High growth potential with Moonshot Grade ${stock.moonshotGrade || 'A'}`;
        case 'smart': return `${stock.valuationRating || 'Undervalued'} with a quality score of ${stock.compassScore}`;
        case 'steady': return `${stock.isGolden ? 'Golden stock — ' : ''}Well-rounded quality at ${stock.compassScore}`;
        default: return `Compass Score: ${stock.compassScore}`;
      }
    }

    // ── Retake ──
    document.getElementById('retake-btn').addEventListener('click', () => {
      localStorage.removeItem('quizProfile');
      answers.experience = null; answers.goal = null; answers.risk = null;
      answers.industries = []; answers.approach = null; answers.barrier = null;
      resultsScreen.classList.add('hidden');
      document.getElementById('welcome-back').classList.add('hidden');
      introScreen.classList.remove('hidden');
      currentStep = -1;
      // Reset all card highlights
      document.querySelectorAll('.answer-card').forEach(c => {
        c.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
        c.classList.add('border-[rgba(255,255,255,0.06)]');
      });
      pillsContainer.querySelectorAll('.industry-pill').forEach(p => {
        p.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10', 'text-[#22D3EE]');
      });
      escapeBtn.classList.remove('border-[#22D3EE]', 'bg-[#22D3EE]/10');
      escapeBtn.classList.add('border-[rgba(255,255,255,0.12)]');
      continueBtn.disabled = true;
      continueBtn.textContent = 'Continue';
      const url = new URL(window.location);
      url.searchParams.delete('profile');
      history.replaceState(null, '', url);
    });

    // ── Share ──
    document.getElementById('share-btn').addEventListener('click', () => {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('share-btn');
        const orig = btn.innerHTML;
        btn.textContent = 'Link copied!';
        setTimeout(() => { btn.innerHTML = orig; }, 2000);
      });
    });
  </script>
</Layout>
