---
import Layout from '../../layouts/Layout.astro';
import { displayIndustries, getIndustryStats } from '../../data/stocks';

const industriesWithStats = displayIndustries.map(ind => ({
  ...ind,
  ...getIndustryStats(ind.name),
}));
---

<Layout title="Browse Stocks by Industry | Compass Score">
  <section class="py-12 bg-[#161B24]">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">Browse Stocks</h1>
        <p class="text-xl text-[#CBD5E1] max-w-2xl mx-auto">
          Explore quality stocks across every sector. Filter by industry or investment goal.
        </p>
      </div>

      <!-- Browse by Industry -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold mb-6">By Industry</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
          {industriesWithStats.map(ind => (
            <a href={`/browse/${ind.name.toLowerCase().replace(/ /g, '-')}`}
               class="bg-[#161B24] border-2 border-[rgba(255,255,255,0.06)] hover:border-[#22D3EE] rounded-xl p-5 transition group">
              <div class="text-3xl mb-3">{ind.icon}</div>
              <h3 class="font-semibold text-lg group-hover:text-[#22D3EE] transition">{ind.name}</h3>
              <div class="mt-2 text-sm text-[#64748B]">
                <span class="font-medium text-slate-700">{ind.count}</span> stocks
              </div>
              <div class="mt-1 text-sm text-[#64748B]">
                Avg score: <span class="font-medium text-slate-700">{ind.avgScore}</span>
              </div>
              {ind.aGradeCount > 0 && (
                <div class="mt-2">
                  <span class="inline-block bg-emerald-100 text-emerald-700 text-xs px-2 py-1 rounded-full">
                    {ind.aGradeCount} A-rated
                  </span>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Browse by Goal -->
      <div>
        <h2 class="text-2xl font-bold mb-6">By Investment Goal</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="/browse/growth" class="bg-gradient-to-br from-purple-500 to-purple-600 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">📈</div>
            <h3 class="font-semibold text-xl">Growth Stocks</h3>
            <p class="text-purple-100 mt-2 text-sm">High-quality companies with strong growth potential</p>
          </a>

          <a href="/browse/dividends" class="bg-gradient-to-br from-green-500 to-green-600 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">💰</div>
            <h3 class="font-semibold text-xl">Dividend Stocks</h3>
            <p class="text-green-100 mt-2 text-sm">Quality companies that pay regular dividends</p>
          </a>

          <a href="/browse/low-risk" class="bg-gradient-to-br from-blue-500 to-blue-600 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">🛡️</div>
            <h3 class="font-semibold text-xl">Low-Risk Quality</h3>
            <p class="text-blue-100 mt-2 text-sm">Stable A & B rated stocks with low volatility</p>
          </a>

          <a href="/browse/under-50" class="bg-gradient-to-br from-amber-500 to-amber-600 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">🏷️</div>
            <h3 class="font-semibold text-xl">Under $50</h3>
            <p class="text-amber-100 mt-2 text-sm">Quality stocks priced under $50 per share</p>
          </a>

          <a href="/browse/under-100" class="bg-gradient-to-br from-teal-500 to-teal-600 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">💵</div>
            <h3 class="font-semibold text-xl">Under $100</h3>
            <p class="text-teal-100 mt-2 text-sm">Quality stocks priced under $100 per share</p>
          </a>

          <a href="/quiz" class="bg-gradient-to-br from-emerald-500 to-cyan-500 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">
              <svg class="w-8 h-8 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="font-semibold text-xl">Find Your Match</h3>
            <p class="text-emerald-100 mt-2 text-sm">Take a 1-minute quiz to discover your investing style</p>
          </a>

          <a href="/tool" class="bg-gradient-to-br from-slate-700 to-slate-800 text-white rounded-xl p-6 hover:shadow-lg transition">
            <div class="text-3xl mb-3">🔍</div>
            <h3 class="font-semibold text-xl">Search Any Stock</h3>
            <p class="text-slate-300 mt-2 text-sm">Look up any of 4,500+ stocks by name or ticker</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
