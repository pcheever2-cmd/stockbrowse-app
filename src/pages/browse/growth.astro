---
import Layout from '../../layouts/Layout.astro';
import { getGrowthStocks, getGradeColor, formatPrice, formatMarketCap, getNormalizedIndustry } from '../../data/stocks';

const stocks = getGrowthStocks();
---

<Layout title="Growth Stocks | Compass Score">
  <section class="py-12 bg-[#161B24] min-h-screen">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-8">
        <a href="/browse" class="text-[#22D3EE] hover:underline text-sm mb-4 inline-block">← Back to Browse</a>
        <div class="flex items-center gap-4">
          <span class="text-5xl">📈</span>
          <div>
            <h1 class="text-4xl font-bold">Growth Stocks</h1>
            <p class="text-[#CBD5E1] mt-1">High-quality companies in growth sectors (Technology, Healthcare, Communication)</p>
          </div>
        </div>
      </div>

      <p class="text-[#CBD5E1] mb-6 max-w-3xl">
        These are quality stocks (B grade or higher) in traditionally growth-oriented sectors.
        Growth stocks typically reinvest profits rather than paying dividends, focusing on expanding their business.
      </p>

      <div class="bg-gradient-to-r from-purple-900/20 to-pink-900/20 rounded-xl p-4 mb-8 border border-purple-500/20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🚀</span>
          <p class="text-sm text-[#CBD5E1]">
            Looking for quality growth stocks? Check out stocks with high <strong class="text-purple-300">Moonshot Scores</strong> -
            our selective score that only ~10% of stocks qualify for.
          </p>
        </div>
        <a href="/moonshot-methodology" class="flex-shrink-0 text-purple-400 hover:text-purple-300 text-sm font-semibold">
          How Moonshot Works →
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {stocks.map(stock => {
          const colors = getGradeColor(stock.grade);
          return (
            <a href={`/stock/${stock.symbol.toLowerCase()}`}
               class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-5 hover:shadow-lg hover:border-emerald-300 transition">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <h3 class="font-bold text-lg">{stock.name}</h3>
                  <p class="text-[#64748B] text-sm">{stock.symbol} • {getNormalizedIndustry(stock.industry)}</p>
                </div>
                <div class={`px-3 py-1 rounded-full ${colors.bg} ${colors.text} font-bold`}>
                  {stock.compassScore}
                </div>
              </div>
              <div class="flex justify-between items-end">
                <div>
                  <div class="text-2xl font-bold">{formatPrice(stock.price)}</div>
                  <div class="text-sm text-[#64748B]">{formatMarketCap(stock.marketCap)} cap</div>
                </div>
                <div class={`text-sm font-semibold ${colors.text}`}>
                  Grade {stock.grade}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
