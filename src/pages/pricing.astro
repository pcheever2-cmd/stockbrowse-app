---
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    description: 'See Compass Scores for 4,500+ stocks',
    features: [
      'Compass Score + Grade (A-F)',
      'Browse all stocks by industry',
      'Stock lookup (unlimited)',
      '1-year price chart',
      'Related stocks',
    ],
    limitations: [
      'No score breakdown',
      'No analyst targets',
      'No valuation rating',
    ],
    cta: 'Start Browsing',
    ctaLink: '/browse/all',
    highlighted: false,
    tier: 'free',
  },
  {
    name: 'Newsletter',
    price: '$1',
    period: '/month',
    description: 'Monthly Compass Report delivered to your inbox',
    features: [
      'Everything in Free',
      'Monthly Compass Report',
      'Top picks + grade changes',
      'Market commentary',
      'Newsletter archive',
    ],
    limitations: [
      'No score breakdown',
      'No analyst targets',
    ],
    cta: 'Subscribe',
    ctaLink: '#',
    highlighted: false,
    tier: 'newsletter',
  },
  {
    name: 'Plus',
    price: '$10',
    period: '/month',
    annualPrice: '$100/yr',
    description: 'The full picture on every stock',
    features: [
      'Everything in Newsletter',
      'Full 6-factor score breakdown',
      'Moonshot Score + Long-Term Score',
      'Analyst price targets + consensus',
      'Analyst accuracy rankings',
      'Financial health (Altman Z, Piotroski)',
      '5-year price chart',
      'Synced watchlist + CSV export',
    ],
    limitations: [],
    cta: 'Get Plus',
    ctaLink: '#',
    highlighted: true,
    tier: 'plus',
  },
  {
    name: 'Pro',
    price: '$15',
    period: '/month',
    annualPrice: '$150/yr',
    description: 'Know when to buy',
    features: [
      'Everything in Plus',
      'Valuation Score (Undervalued / Overvalued)',
      'Up to 5 named watchlists',
      'SMS alerts for grade changes',
    ],
    limitations: [],
    cta: 'Get Pro',
    ctaLink: '#',
    highlighted: false,
    tier: 'pro',
  },
];
---

<Layout title="Pricing | Compass Score">
  <section class="py-16 bg-[#080A0F] min-h-screen">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Simple, Transparent Pricing</h1>
        <p class="text-xl text-[#CBD5E1] max-w-2xl mx-auto">
          Choose the plan that fits your investment style.
        </p>
      </div>

      <!-- Monthly/Annual Toggle -->
      <div class="flex items-center justify-center gap-3 mb-12">
        <span id="monthlyLabel" class="text-sm font-semibold text-slate-100">Monthly</span>
        <button id="billingToggle" class="relative w-14 h-7 bg-[#161B24] border border-[rgba(255,255,255,0.1)] rounded-full transition">
          <div id="toggleDot" class="absolute top-0.5 left-0.5 w-6 h-6 bg-[#22D3EE] rounded-full transition-transform"></div>
        </button>
        <span id="annualLabel" class="text-sm text-[#64748B]">Annual <span class="text-emerald-400">(2 months free)</span></span>
      </div>

      <!-- Pricing Cards -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {tiers.map(tier => (
          <div class={`relative bg-[#161B24] rounded-2xl border-2 ${tier.highlighted ? 'border-[#22D3EE] shadow-xl scale-105' : 'border-[rgba(255,255,255,0.06)]'} p-6 flex flex-col`}>
            {tier.highlighted && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#22D3EE] text-white px-4 py-1 rounded-full text-sm font-semibold">
                Most Popular
              </div>
            )}

            <div class="mb-6">
              <h3 class="text-xl font-bold mb-2">{tier.name}</h3>
              <div class="flex items-baseline gap-1">
                <span class="text-4xl font-bold" data-monthly-price={tier.price} data-annual-price={tier.annualPrice || tier.price}>{tier.price}</span>
                <span class="text-[#64748B]" data-monthly-period={tier.period} data-annual-period={tier.annualPrice ? '/yr' : tier.period}>{tier.period}</span>
              </div>
              <p class="text-[#CBD5E1] text-sm mt-2">{tier.description}</p>
            </div>

            <ul class="space-y-3 mb-6 flex-grow">
              {tier.features.map(feature => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-[#22D3EE] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm">{feature}</span>
                </li>
              ))}
              {tier.limitations.map(limitation => (
                <li class="flex items-start gap-2 text-slate-400">
                  <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                  <span class="text-sm">{limitation}</span>
                </li>
              ))}
            </ul>

            <button
              data-tier={tier.tier}
              class={`pricing-cta block text-center py-3 px-6 rounded-xl font-semibold transition ${
                tier.highlighted
                  ? 'bg-[#22D3EE] hover:bg-[#06B6D4] text-white'
                  : tier.tier === 'free'
                    ? 'bg-[#0C0F14] hover:bg-[#1C222E] text-slate-100 border border-[rgba(255,255,255,0.1)]'
                    : 'bg-[#0C0F14] hover:bg-[#1C222E] text-slate-100 border border-[rgba(255,255,255,0.1)]'
              }`}>
              {tier.cta}
            </button>
          </div>
        ))}
      </div>

      <!-- FAQ Section -->
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>

        <div class="space-y-4">
          <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6">
            <h3 class="font-semibold mb-2">What's the Valuation Score?</h3>
            <p class="text-[#CBD5E1] text-sm">
              The Valuation Score tells you if a stock is currently undervalued, fair value, or overvalued
              based on its price relative to long-term moving averages and 52-week range.
              It's the "should I buy now?" answer — exclusive to Pro.
            </p>
          </div>

          <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6">
            <h3 class="font-semibold mb-2">Can I change plans later?</h3>
            <p class="text-[#CBD5E1] text-sm">
              Yes! You can upgrade or downgrade at any time. If you upgrade,
              you'll be charged the prorated difference. If you downgrade, you'll receive
              credit toward future billing.
            </p>
          </div>

          <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6">
            <h3 class="font-semibold mb-2">What payment methods do you accept?</h3>
            <p class="text-[#CBD5E1] text-sm">
              We accept all major credit cards (Visa, MasterCard, American Express) via Stripe.
            </p>
          </div>

          <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6">
            <h3 class="font-semibold mb-2">How is the Compass Score calculated?</h3>
            <p class="text-[#CBD5E1] text-sm">
              The Compass Score is based on peer-reviewed academic research on stock quality factors.
              It combines 6 metrics: Return on Assets, Gross Profitability, Operating Cash Flow,
              Free Cash Flow, Volatility, and Asset Growth. <a href="/how-it-works" class="text-[#22D3EE] hover:underline">Learn more</a>
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script>
    import { supabase } from '../lib/supabase';

    // Monthly/Annual toggle
    let isAnnual = false;
    const toggle = document.getElementById('billingToggle')!;
    const dot = document.getElementById('toggleDot')!;
    const monthlyLabel = document.getElementById('monthlyLabel')!;
    const annualLabel = document.getElementById('annualLabel')!;

    toggle.addEventListener('click', () => {
      isAnnual = !isAnnual;
      dot.style.transform = isAnnual ? 'translateX(28px)' : 'translateX(0)';
      monthlyLabel.className = `text-sm ${isAnnual ? 'text-[#64748B]' : 'font-semibold text-slate-100'}`;
      annualLabel.className = `text-sm ${isAnnual ? 'font-semibold text-slate-100' : 'text-[#64748B]'}`;

      // Update displayed prices
      document.querySelectorAll('[data-monthly-price]').forEach(el => {
        const htmlEl = el as HTMLElement;
        htmlEl.textContent = isAnnual
          ? htmlEl.dataset.annualPrice || htmlEl.dataset.monthlyPrice || ''
          : htmlEl.dataset.monthlyPrice || '';
      });
      document.querySelectorAll('[data-monthly-period]').forEach(el => {
        const htmlEl = el as HTMLElement;
        htmlEl.textContent = isAnnual
          ? htmlEl.dataset.annualPeriod || htmlEl.dataset.monthlyPeriod || ''
          : htmlEl.dataset.monthlyPeriod || '';
      });
    });

    // CTA buttons — route to checkout or browse
    document.querySelectorAll('.pricing-cta').forEach(btn => {
      btn.addEventListener('click', async () => {
        const tier = (btn as HTMLElement).dataset.tier;
        if (!tier || tier === 'free') {
          window.location.href = '/browse/all';
          return;
        }

        // Check if user is logged in
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          // Redirect to signup with a return to pricing
          window.location.href = `/signup?redirect=/pricing`;
          return;
        }

        // Create checkout session
        (btn as HTMLButtonElement).disabled = true;
        (btn as HTMLButtonElement).textContent = 'Redirecting...';

        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ tier, annual: isAnnual }),
          });

          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert(data.error || 'Failed to start checkout');
            (btn as HTMLButtonElement).disabled = false;
            (btn as HTMLButtonElement).textContent = 'Try Again';
          }
        } catch {
          alert('Something went wrong. Please try again.');
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    });
  </script>
</Layout>
