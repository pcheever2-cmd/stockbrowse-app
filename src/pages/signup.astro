---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Create Account | Compass Score">
  <section class="py-16 bg-[#080A0F] min-h-screen flex items-center justify-center">
    <div class="max-w-md w-full mx-auto px-4">
      <div class="bg-[#161B24] rounded-2xl border border-[rgba(255,255,255,0.06)] p-8">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold mb-2">Create your account</h1>
          <p class="text-[#CBD5E1]">Start making better investment decisions</p>
        </div>

        <div id="errorMessage" class="hidden bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg p-3 mb-4 text-sm"></div>
        <div id="successMessage" class="hidden bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-lg p-3 mb-4 text-sm"></div>

        <form id="signupForm" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-[#CBD5E1] mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 bg-[#080A0F] border border-[rgba(255,255,255,0.1)] rounded-lg text-slate-100 focus:border-[#22D3EE] focus:outline-none transition" />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-[#CBD5E1] mb-1">Password</label>
            <input type="password" id="password" name="password" required minlength="10"
              class="w-full px-4 py-3 bg-[#080A0F] border border-[rgba(255,255,255,0.1)] rounded-lg text-slate-100 focus:border-[#22D3EE] focus:outline-none transition" />
            <p class="text-xs text-[#64748B] mt-1">Minimum 10 characters</p>
          </div>
          <button type="submit" id="submitBtn"
            class="w-full py-3 bg-[#22D3EE] hover:bg-[#06B6D4] text-white rounded-lg font-semibold transition">
            Create Account
          </button>
        </form>

        <div class="mt-6 text-center text-sm text-[#64748B]">
          Already have an account? <a href="/login" class="text-[#22D3EE] hover:underline">Sign in</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '../lib/supabase';

    const form = document.getElementById('signupForm') as HTMLFormElement;
    const errorDiv = document.getElementById('errorMessage')!;
    const successDiv = document.getElementById('successMessage')!;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating account...';

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      const { error } = await supabase.auth.signUp({ email, password });

      if (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
        return;
      }

      successDiv.textContent = 'Check your email to verify your account, then sign in.';
      successDiv.classList.remove('hidden');
      form.classList.add('hidden');
    });
  </script>
</Layout>
