---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Learn to Invest | Compass Score Blog">
  <section class="py-16 bg-[#161B24]">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">Learn to Invest Smarter</h1>
        <p class="text-xl text-[#CBD5E1]">
          Practical guides and insights for building a quality stock portfolio.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-12 bg-[#080A0F] rounded-2xl">
          <p class="text-[#CBD5E1]">Articles coming soon! Check back later.</p>
        </div>
      ) : (
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="bg-[#080A0F] rounded-xl p-6 hover:shadow-lg transition">
              <a href={`/blog/${post.id}`} class="block">
                <p class="text-[#22D3EE] text-sm font-semibold mb-2">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </p>
                <h2 class="text-2xl font-bold mb-2 hover:text-[#22D3EE] transition">
                  {post.data.title}
                </h2>
                <p class="text-[#CBD5E1]">{post.data.description}</p>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
