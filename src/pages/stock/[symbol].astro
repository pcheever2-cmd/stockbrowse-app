---
import Layout from '../../layouts/Layout.astro';
import UpgradeModal from '../../components/UpgradeModal.astro';
import {
  stocks,
  getStockBySymbol,
  getGradeColor,
  generateSummary,
  getCompanyProfile,
  formatPrice,
  formatMarketCap,
  getNormalizedIndustry,
  getRelatedStocks,
  getScoreBreakdown,
  getFactorRatingColor,
  getConsensusInfo,
  parseRecentRatings,
  parseAnalystPriceTargets
} from '../../data/stocks';

export function getStaticPaths() {
  return stocks.map(stock => ({
    params: { symbol: stock.symbol.toLowerCase() },
    props: { stock }
  }));
}

const { stock } = Astro.props;
const colors = getGradeColor(stock.grade);
const summary = generateSummary(stock);
const companyProfile = getCompanyProfile(stock);
const industry = getNormalizedIndustry(stock.industry);
const relatedStocks = getRelatedStocks(stock, 6);
const breakdown = getScoreBreakdown(stock);

// Analyst data
const hasAnalystData = stock.numAnalysts && stock.numAnalysts > 0;
const consensusInfo = getConsensusInfo(stock.consensus, stock.recentRatings, stock.upside);
const recentRatings = parseRecentRatings(stock.recentRatings);

// Create a map of firm -> most recent rating with date for cross-referencing
const firmRatingsMap = new Map<string, { rating: string; icon: string; date: string }>();
recentRatings.forEach(r => {
  // Only keep the first (most recent) rating for each firm
  if (!firmRatingsMap.has(r.firm)) {
    firmRatingsMap.set(r.firm, { rating: r.rating, icon: r.icon, date: r.date });
  }
});

// Parse individual analyst price targets and create a map
const analystPriceTargets = parseAnalystPriceTargets(stock.analystPriceTargets || '');
const firmPriceTargetMap = new Map<string, { priceTarget: number; priceWhenPosted: number | null; date: string }>();
analystPriceTargets.forEach(pt => {
  // Only keep the first (most recent) price target for each firm
  if (!firmPriceTargetMap.has(pt.firm)) {
    firmPriceTargetMap.set(pt.firm, { priceTarget: pt.priceTarget, priceWhenPosted: pt.priceWhenPosted, date: pt.date });
  }
});

// Enhance covering analysts with rating dates, price targets, and sort by accuracy + recency
const enhancedAnalysts = stock.coveringAnalysts ? stock.coveringAnalysts.map(analyst => {
  const firmRating = firmRatingsMap.get(analyst.firm);
  const firmPriceTarget = firmPriceTargetMap.get(analyst.firm);
  return {
    ...analyst,
    rating: firmRating?.rating || null,
    ratingDate: firmRating?.date || null,
    priceTarget: firmPriceTarget?.priceTarget || null,
    priceTargetDate: firmPriceTarget?.date || null
  };
}).sort((a, b) => {
  // Primary sort: highest hit rate first
  if (b.hitRate !== a.hitRate) return b.hitRate - a.hitRate;
  // Secondary sort: most recent date first
  if (a.ratingDate && b.ratingDate) {
    return b.ratingDate.localeCompare(a.ratingDate);
  }
  // Analysts with dates come before those without
  if (a.ratingDate && !b.ratingDate) return -1;
  if (!a.ratingDate && b.ratingDate) return 1;
  return 0;
}) : [];

// Helper to get rating badge color
function getRatingColor(rating: string): { bg: string; text: string } {
  const r = rating.toLowerCase();
  if (r.includes('buy') || r.includes('outperform') || r.includes('overweight')) {
    return { bg: 'bg-emerald-500/20', text: 'text-emerald-400' };
  }
  if (r.includes('sell') || r.includes('underperform') || r.includes('underweight')) {
    return { bg: 'bg-red-500/20', text: 'text-red-400' };
  }
  return { bg: 'bg-amber-500/20', text: 'text-amber-400' }; // Neutral/Hold
}

// Factor definitions with universe averages and details
const factors = [
  {
    key: 'roa',
    name: 'Return on Assets',
    description: 'How efficiently the company uses its assets to generate profit',
    average: 2,
    unit: '%',
    detail: 'Measures net income divided by total assets. Higher ROA indicates better efficiency at converting assets into profit.',
    inverted: false
  },
  {
    key: 'grossProfit',
    name: 'Gross Profitability',
    description: 'Revenue minus cost of goods sold, relative to assets',
    average: 25,
    unit: '%',
    detail: 'Gross profit divided by total assets. Companies with higher gross profitability tend to outperform.',
    inverted: false
  },
  {
    key: 'operatingCashFlow',
    name: 'Operating Cash Flow',
    description: 'Cash generated from normal business operations',
    average: 5,
    unit: '%',
    detail: 'Operating cash flow divided by total assets. Real cash generation, not accounting earnings.',
    inverted: false
  },
  {
    key: 'freeCashFlow',
    name: 'Free Cash Flow',
    description: 'Cash available after capital expenditures',
    average: 3,
    unit: '%',
    detail: 'Free cash flow divided by total assets. Money available to return to shareholders.',
    inverted: false
  },
  {
    key: 'volatility',
    name: 'Low Volatility',
    description: 'Stock price stability (lower is better)',
    average: 45,
    unit: '%',
    detail: '60-day annualized volatility. Lower volatility stocks historically deliver better risk-adjusted returns.',
    inverted: true
  },
  {
    key: 'assetGrowth',
    name: 'Conservative Growth',
    description: 'Measured asset expansion (slower is often better)',
    average: 10,
    unit: '%',
    detail: 'Year-over-year asset growth. Companies that grow conservatively tend to outperform aggressive expanders.',
    inverted: true
  },
];

// Get factor value for display
function getFactorValue(key: string): number | null {
  if (!stock.factorValues) return null;
  return stock.factorValues[key as keyof typeof stock.factorValues];
}

// Helper functions for data display
function formatPiotroski(score: number | null): { value: string; label: string; color: string } {
  if (score === null) return { value: 'N/A', label: 'Unknown', color: 'text-slate-400' };
  if (score >= 7) return { value: `${score}/9`, label: 'Strong', color: 'text-emerald-400' };
  if (score >= 4) return { value: `${score}/9`, label: 'Average', color: 'text-slate-300' };
  return { value: `${score}/9`, label: 'Weak', color: 'text-red-400' };
}

function formatAltmanZ(z: number | null): { value: string; label: string; color: string } {
  if (z === null) return { value: 'N/A', label: 'Unknown', color: 'text-slate-400' };
  if (z >= 2.99) return { value: z.toFixed(2), label: 'Safe Zone', color: 'text-emerald-400' };
  if (z >= 1.81) return { value: z.toFixed(2), label: 'Grey Zone', color: 'text-amber-400' };
  return { value: z.toFixed(2), label: 'Distress Zone', color: 'text-red-400' };
}

function formatRsi(rsi: number | null): { value: string; label: string; color: string } {
  if (rsi === null) return { value: 'N/A', label: 'Unknown', color: 'text-slate-400' };
  if (rsi >= 70) return { value: rsi.toFixed(0), label: 'Overbought', color: 'text-red-400' };
  if (rsi <= 30) return { value: rsi.toFixed(0), label: 'Oversold', color: 'text-emerald-400' };
  return { value: rsi.toFixed(0), label: 'Neutral', color: 'text-slate-300' };
}

const rsiInfo = formatRsi(stock.rsi);
const piotroskiInfo = formatPiotroski(stock.piotroskiScore);
const altmanInfo = formatAltmanZ(stock.altmanZ);

// Moonshot score display
const hasMoonshot = stock.moonshotScore !== null && stock.moonshotGrade !== null;
const moonshotColors = hasMoonshot ? getGradeColor(stock.moonshotGrade!) : null;
---

<Layout title={`${stock.name} (${stock.symbol}) Compass Score | Stockbrowse`}>
  <section class="py-12 bg-[#0C0F14] min-h-screen">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Back Link - uses history.back() if coming from browse page to preserve filters -->
      <a href="/browse/all" onclick="if(document.referrer.includes('/browse/')) { history.back(); return false; }" class="text-[#22D3EE] hover:underline text-sm mb-6 inline-block">&larr; Back to Browse</a>

      <!-- Header with Score -->
      <div class="rounded-2xl p-8 bg-[#161B24] border border-[rgba(255,255,255,0.06)] mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold text-slate-100">{stock.name}</h1>
            <p class="text-lg text-[#CBD5E1] mt-1">{stock.symbol} &bull; {industry}</p>
          </div>
          <div class="flex items-center gap-4">
            <!-- Compass Score -->
            <div class="text-center">
              <div class={`w-28 h-28 rounded-full bg-[#0C0F14] border-4 ${colors.border} flex items-center justify-center mx-auto shadow-lg`}>
                <div>
                  <div class={`text-3xl font-bold ${colors.text}`}>{stock.compassScore}</div>
                  <div class={`text-xs font-semibold ${colors.text}`}>Grade {stock.grade}</div>
                </div>
              </div>
              <div class="text-xs text-[#64748B] mt-2">Compass</div>
            </div>

            <!-- Moonshot Score (if available) -->
            {hasMoonshot && moonshotColors && (
              <div class="text-center">
                <div class={`w-28 h-28 rounded-full bg-[#0C0F14] border-4 ${moonshotColors.border} flex items-center justify-center mx-auto shadow-lg`}>
                  <div>
                    <div class={`text-3xl font-bold ${moonshotColors.text}`}>{stock.moonshotScore}</div>
                    <div class={`text-xs font-semibold ${moonshotColors.text}`}>Grade {stock.moonshotGrade}</div>
                  </div>
                </div>
                <div class="text-xs text-[#64748B] mt-2">Moonshot</div>
              </div>
            )}

          </div>
        </div>
      </div>

      <!-- Price & Market Cap (Free) -->
      <div class="grid md:grid-cols-2 gap-4 mb-8">
        <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-5">
          <div class="text-sm text-[#64748B] mb-1">Current Price</div>
          <div class="text-3xl font-bold text-slate-100">{formatPrice(stock.price)}</div>
        </div>
        <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-5">
          <div class="text-sm text-[#64748B] mb-1">Market Cap</div>
          <div class="text-3xl font-bold text-slate-100">{formatMarketCap(stock.marketCap)}</div>
        </div>
      </div>

      <!-- Company Profile (Free) -->
      {companyProfile && (
        <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
          <h2 class="text-xl font-bold mb-3 text-slate-100">About {stock.name}</h2>
          <p class="text-[#CBD5E1] leading-relaxed">{companyProfile}</p>
        </div>
      )}

      <!-- Quality Assessment (Free) -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-3 text-slate-100">Quality Assessment</h2>
        <p class={`${colors.text} leading-relaxed text-lg`}>{summary}</p>
      </div>

      <!-- Score Context Note (for holding companies, etc.) -->
      {stock.scoreNote && (
        <div class="bg-blue-900/20 border border-blue-700/30 rounded-xl p-6 mb-8">
          <div class="flex items-start gap-3">
            <span class="text-2xl">ℹ️</span>
            <div>
              <h3 class="font-semibold text-blue-400 mb-2">{stock.scoreNote.title}</h3>
              <p class="text-sm text-blue-200/80 leading-relaxed">{stock.scoreNote.text}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Score Breakdown (Free: labels only, Premium: actual values on click) -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-4 text-slate-100">Score Breakdown</h2>
        <p class="text-[#64748B] text-sm mb-6">
          The Compass Score is based on 6 quality factors identified by academic research.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {factors.map(factor => {
            const rating = breakdown[factor.key as keyof typeof breakdown];
            const ratingColors = getFactorRatingColor(rating);
            const factorValue = getFactorValue(factor.key);
            const displayValue = factorValue !== null ? `${factorValue.toFixed(1)}${factor.unit}` : 'N/A';
            return (
              <div class="factor-wrapper">
                <button
                  data-factor={factor.key}
                  data-factor-name={factor.name}
                  data-factor-value={displayValue}
                  data-factor-average={factor.average}
                  data-factor-detail={factor.detail}
                  data-factor-inverted={factor.inverted}
                  class="factor-card flex items-center justify-between p-4 bg-[#080A0F] rounded-lg hover:bg-[#0F1419] cursor-pointer transition group text-left w-full border border-transparent hover:border-[#22D3EE33]"
                >
                  <div>
                    <div class="font-semibold text-slate-100 group-hover:text-[#22D3EE] transition">{factor.name}</div>
                    <div class="text-xs text-[#64748B]">{factor.description}</div>
                  </div>
                  <span class={`px-3 py-1 rounded-full text-sm font-semibold ${ratingColors.bg} ${ratingColors.text}`}>
                    {ratingColors.label}
                  </span>
                </button>
                <!-- Expandable detail panel (hidden by default) -->
                <div class="factor-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-sm text-[#64748B]">{stock.name}'s Value:</span>
                    <span class={`text-xl font-bold ${ratingColors.text}`}>{displayValue}</span>
                  </div>
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-sm text-[#64748B]">Universe Average:</span>
                    <span class="text-sm text-slate-400">{factor.average}{factor.unit}</span>
                  </div>
                  <p class="text-xs text-[#CBD5E1] leading-relaxed">{factor.detail}</p>
                  {factor.inverted && (
                    <p class="text-xs text-[#22D3EE] mt-2 italic">Note: For this factor, lower values are better.</p>
                  )}
                </div>
              </div>
            );
          })}
        </div>
        <div class="mt-4 text-center">
          <p class="text-xs text-[#64748B]">Click any factor to see detailed metrics</p>
        </div>
      </div>

      <!-- FREE SECTION: Valuation Metrics (Yahoo Finance available) -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-4 text-slate-100">Valuation Metrics</h2>
        <p class="text-[#64748B] text-xs mb-4">Click any metric for details</p>
        <div class="grid grid-cols-3 gap-4">
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">EV/EBITDA</div>
              <div class="text-2xl font-bold text-slate-100">{stock.evEbitda?.toFixed(1) || 'N/A'}</div>
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">Enterprise Value to EBITDA</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                Compares a company's total value (including debt) to its operating earnings before interest, taxes, depreciation, and amortization.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-emerald-400">Lower is generally better</span> — suggests the company may be undervalued relative to its earnings power. Typical ranges vary by industry: tech often trades at 15-25x, while utilities may trade at 8-12x.
              </p>
            </div>
          </div>
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">Forward P/E</div>
              <div class="text-2xl font-bold text-slate-100">{stock.forwardPe?.toFixed(1) || 'N/A'}</div>
              {stock.sectorPe && stock.forwardPe && (
                <div class={`text-xs mt-1 ${stock.forwardPe < stock.sectorPe ? 'text-emerald-400' : stock.forwardPe > stock.sectorPe * 1.2 ? 'text-amber-400' : 'text-[#64748B]'}`}>
                  Sector: {stock.sectorPe.toFixed(1)}
                </div>
              )}
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">Forward Price-to-Earnings</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                Stock price divided by expected earnings per share over the next 12 months. Uses analyst estimates for future earnings rather than historical data.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-emerald-400">Below the sector average</span> may indicate relative value. <span class="text-red-400">Above sector</span> could mean it's expensive, or investors expect higher growth. Growth stocks typically have higher P/Es.
              </p>
            </div>
          </div>
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">PEG Ratio</div>
              <div class="text-2xl font-bold text-slate-100">{stock.pegRatio?.toFixed(2) || 'N/A'}</div>
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">Price/Earnings-to-Growth Ratio</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                P/E ratio divided by expected earnings growth rate. Adjusts valuation for growth expectations — a high P/E might be justified if the company is growing fast.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-emerald-400">PEG under 1.0</span> suggests the stock may be undervalued relative to its growth. <span class="text-amber-400">PEG of 1.0-2.0</span> is typical for quality growth stocks. <span class="text-red-400">PEG over 2.0</span> may indicate overvaluation.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Valuation Score (Technical Valuation) -->
      {stock.valuationRating != null && (
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-slate-100">Technical Valuation</h2>
          <a href="/valuation-methodology" class="text-xs text-[#64748B] hover:text-[#22D3EE] transition">How it works →</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
          <div class="bg-[#080A0F] rounded-lg p-4 text-center">
            <div class="text-sm text-[#64748B] mb-1">Rating</div>
            <div class={`text-xl font-bold ${stock.valuationRating === 'Undervalued' ? 'text-emerald-400' : stock.valuationRating === 'Fair Value' ? 'text-amber-400' : 'text-red-400'}`}>
              {stock.valuationRating}
            </div>
          </div>

          {stock.valuationData && (
          <>
          <div class="bg-[#080A0F] rounded-lg p-4 text-center">
            <div class="text-sm text-[#64748B] mb-1">vs SMA200</div>
            <div class={`text-2xl font-bold ${(stock.valuationData.vsSma200 ?? 0) < 0 ? 'text-emerald-400' : 'text-red-400'}`}>
              {stock.valuationData.vsSma200 != null ? `${stock.valuationData.vsSma200 > 0 ? '+' : ''}${stock.valuationData.vsSma200}%` : 'N/A'}
            </div>
            <div class="text-xs text-[#64748B] mt-1">{(stock.valuationData.vsSma200 ?? 0) < 0 ? 'Below avg' : 'Above avg'}</div>
          </div>

          <div class="bg-[#080A0F] rounded-lg p-4 text-center">
            <div class="text-sm text-[#64748B] mb-1">vs SMA50</div>
            <div class={`text-2xl font-bold ${(stock.valuationData.vsSma50 ?? 0) < 0 ? 'text-emerald-400' : 'text-red-400'}`}>
              {stock.valuationData.vsSma50 != null ? `${stock.valuationData.vsSma50 > 0 ? '+' : ''}${stock.valuationData.vsSma50}%` : 'N/A'}
            </div>
            <div class="text-xs text-[#64748B] mt-1">{(stock.valuationData.vsSma50 ?? 0) < 0 ? 'Below avg' : 'Above avg'}</div>
          </div>

          <div class="bg-[#080A0F] rounded-lg p-4 text-center">
            <div class="text-sm text-[#64748B] mb-1">52W Range</div>
            <div class="text-2xl font-bold text-slate-100">
              {stock.valuationData.position52w != null ? `${stock.valuationData.position52w}%` : 'N/A'}
            </div>
            <div class="text-xs text-[#64748B] mt-1">
              {stock.valuationData.low52w != null && stock.valuationData.high52w != null
                ? `$${stock.valuationData.low52w.toFixed(2)} - $${stock.valuationData.high52w.toFixed(2)}`
                : ''}
            </div>
          </div>
          </>
          )}
        </div>

        <div class="bg-[#080A0F] rounded-lg p-3">
          <p class="text-xs text-[#64748B]">
            {stock.valuationRating === 'Undervalued'
              ? stock.upside && stock.upside > 10
                ? '✓ Both technical valuation and analyst targets suggest this stock may be undervalued.'
                : 'Technically undervalued — trading below moving averages. Check analyst targets for confirmation.'
              : stock.valuationRating === 'Fair Value'
                ? 'Trading near fair value based on moving averages. No strong technical signal.'
                : stock.upside && stock.upside > 20
                  ? '⚠ Analysts see upside, but the stock is technically overextended above moving averages.'
                  : 'Trading above moving averages — technically overvalued. Consider waiting for a pullback.'}
          </p>
        </div>
      </div>
      )}

      <!-- FREE SECTION: Technical Overview (Yahoo Finance available) -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-4 text-slate-100">Technical Overview</h2>
        <p class="text-[#64748B] text-xs mb-4">Click any metric for details</p>
        <div class="grid grid-cols-3 gap-4">
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">RSI (14)</div>
              <div class={`text-2xl font-bold ${rsiInfo.color}`}>{rsiInfo.value}</div>
              <div class={`text-xs ${rsiInfo.color}`}>{rsiInfo.label}</div>
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">Relative Strength Index (14-day)</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                Momentum indicator measuring the speed and magnitude of recent price changes on a scale of 0-100.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-red-400">Above 70 (Overbought)</span>: Stock may have risen too quickly and could be due for a pullback.
                <br/><span class="text-emerald-400">Below 30 (Oversold)</span>: Stock may have fallen too much and could be due for a bounce.
                <br/><span class="text-slate-300">30-70 (Neutral)</span>: Neither overbought nor oversold.
              </p>
            </div>
          </div>
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">vs 50-Day SMA</div>
              <div class={`text-2xl font-bold ${stock.sma50 && stock.price > stock.sma50 ? 'text-emerald-400' : 'text-red-400'}`}>
                {stock.sma50 ? (stock.price > stock.sma50 ? 'Above' : 'Below') : 'N/A'}
              </div>
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">50-Day Simple Moving Average</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                The average closing price over the past 50 trading days. Used to identify short-term trends.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-emerald-400">Above the 50-day SMA</span>: Stock is in a short-term uptrend. Often seen as bullish — buyers are in control recently.
                <br/><span class="text-red-400">Below the 50-day SMA</span>: Stock is in a short-term downtrend. May signal weakness or selling pressure.
              </p>
            </div>
          </div>
          <div class="metric-wrapper">
            <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
              <div class="text-sm text-[#64748B] mb-1">vs 200-Day SMA</div>
              <div class={`text-2xl font-bold ${stock.sma200 && stock.price > stock.sma200 ? 'text-emerald-400' : 'text-red-400'}`}>
                {stock.sma200 ? (stock.price > stock.sma200 ? 'Above' : 'Below') : 'N/A'}
              </div>
            </button>
            <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
              <h4 class="font-semibold text-slate-100 mb-2">200-Day Simple Moving Average</h4>
              <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                The average closing price over the past 200 trading days. The most widely followed indicator for long-term trend direction.
              </p>
              <p class="text-xs text-[#64748B]">
                <span class="text-emerald-400">Above the 200-day SMA</span>: Stock is in a long-term uptrend. Generally considered bullish — the stock has sustained momentum.
                <br/><span class="text-red-400">Below the 200-day SMA</span>: Stock is in a long-term downtrend. Often seen as a warning sign by technical traders.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- FREE SECTION: Wall Street View - Full (Yahoo Finance available) -->
      {hasAnalystData && (
        <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
          <h2 class="text-xl font-bold mb-4 text-slate-100">Wall Street View</h2>

          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div class={`${consensusInfo.bgColor} rounded-lg p-4 text-center`}>
              <div class="text-sm text-[#64748B] mb-1">Consensus</div>
              <div class={`text-xl font-bold ${consensusInfo.color}`}>{consensusInfo.label}</div>
            </div>
            <div class="bg-[#080A0F] rounded-lg p-4 text-center">
              <div class="text-sm text-[#64748B] mb-1">Analysts</div>
              <div class="text-xl font-bold text-slate-100">{stock.numAnalysts}</div>
            </div>
            <div class="bg-[#080A0F] rounded-lg p-4 text-center">
              <div class="text-sm text-[#64748B] mb-1">Price Target</div>
              <div class="text-xl font-bold text-slate-100">{stock.avgPriceTarget ? `$${stock.avgPriceTarget.toFixed(0)}` : 'N/A'}</div>
            </div>
            <div class="bg-[#080A0F] rounded-lg p-4 text-center">
              <div class="text-sm text-[#64748B] mb-1">Upside</div>
              <div class={`text-xl font-bold ${stock.upside && stock.upside > 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                {stock.upside !== null ? `${stock.upside > 0 ? '+' : ''}${stock.upside}%` : 'N/A'}
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Growth Projections -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-4 text-slate-100">Growth Projections</h2>

        <div class="premium-content">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-[#080A0F] rounded-lg p-4 text-center">
              <div class="text-sm text-[#64748B] mb-1">Projected EPS Growth</div>
              <div class={`text-2xl font-bold ${stock.epsGrowth && stock.epsGrowth > 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                {stock.epsGrowth ? `${stock.epsGrowth > 0 ? '+' : ''}${stock.epsGrowth.toFixed(1)}%` : 'N/A'}
              </div>
            </div>
            <div class="bg-[#080A0F] rounded-lg p-4 text-center">
              <div class="text-sm text-[#64748B] mb-1">Projected Revenue Growth</div>
              <div class={`text-2xl font-bold ${stock.revenueGrowth && stock.revenueGrowth > 0 ? 'text-emerald-400' : 'text-red-400'}`}>
                {stock.revenueGrowth ? `${stock.revenueGrowth > 0 ? '+' : ''}${stock.revenueGrowth.toFixed(1)}%` : 'N/A'}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Financial Health -->
      <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold mb-4 text-slate-100">Financial Health</h2>
        <p class="text-[#64748B] text-xs mb-4">Click any metric for details</p>

        <div class="premium-content">
          <div class="grid grid-cols-2 gap-4">
            <div class="metric-wrapper">
              <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
                <div class="text-sm text-[#64748B] mb-1">Piotroski F-Score</div>
                <div class={`text-2xl font-bold ${piotroskiInfo.color}`}>{piotroskiInfo.value}</div>
                <div class={`text-xs ${piotroskiInfo.color}`}>{piotroskiInfo.label}</div>
              </button>
              <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
                <h4 class="font-semibold text-slate-100 mb-2">Piotroski F-Score</h4>
                <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                  A 9-point scoring system that evaluates a company's financial strength based on profitability, leverage, liquidity, and operating efficiency.
                </p>
                <p class="text-xs text-[#64748B]">
                  <span class="text-emerald-400">7-9 (Strong)</span>: Excellent financial health with improving fundamentals.
                  <br/><span class="text-slate-300">4-6 (Average)</span>: Mixed financial signals.
                  <br/><span class="text-red-400">0-3 (Weak)</span>: Potential financial distress or deteriorating fundamentals.
                </p>
              </div>
            </div>
            <div class="metric-wrapper">
              <button class="metric-card bg-[#080A0F] rounded-lg p-4 text-center w-full hover:bg-[#0F1419] cursor-pointer transition border border-transparent hover:border-[#22D3EE33]">
                <div class="text-sm text-[#64748B] mb-1">Altman Z-Score</div>
                <div class={`text-2xl font-bold ${altmanInfo.color}`}>{altmanInfo.value}</div>
                <div class={`text-xs ${altmanInfo.color}`}>{altmanInfo.label}</div>
              </button>
              <div class="metric-detail hidden mt-2 p-4 bg-[#0F1419] rounded-lg border border-[#22D3EE33]">
                <h4 class="font-semibold text-slate-100 mb-2">Altman Z-Score</h4>
                <p class="text-xs text-[#CBD5E1] leading-relaxed mb-2">
                  A formula predicting the probability of bankruptcy within 2 years, combining 5 financial ratios including working capital, retained earnings, and sales.
                </p>
                <p class="text-xs text-[#64748B]">
                  <span class="text-emerald-400">Above 2.99 (Safe)</span>: Low bankruptcy risk.
                  <br/><span class="text-amber-400">1.81-2.99 (Grey Zone)</span>: Moderate risk, warrants monitoring.
                  <br/><span class="text-red-400">Below 1.81 (Distress)</span>: Elevated bankruptcy risk.
                </p>
                <p class="text-xs text-amber-400 mt-2 italic">
                  Note: The Altman Z-Score was originally designed for manufacturing companies. It may be less reliable for financial firms, utilities, or service-based businesses.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Analyst Track Record -->
      {(stock.sectorAnalystAccuracy || (stock.coveringAnalysts && stock.coveringAnalysts.length > 0)) && (
        <div class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-6 mb-8">
          <h2 class="text-xl font-bold mb-4 text-slate-100">Analyst Track Record</h2>

          <div class="premium-content">
            {stock.sectorAnalystAccuracy && (
              <div class="mb-4 p-4 bg-[#080A0F] rounded-lg">
                <div class="text-sm text-[#64748B] mb-1">{stock.sector} Sector Accuracy</div>
                <div class={`text-2xl font-bold ${stock.sectorAnalystAccuracy >= 55 ? 'text-emerald-400' : stock.sectorAnalystAccuracy >= 50 ? 'text-amber-400' : 'text-red-400'}`}>
                  {stock.sectorAnalystAccuracy}%
                </div>
                <div class="text-xs text-[#64748B] mt-1">Average accuracy across all analysts in this sector</div>
              </div>
            )}

            {enhancedAnalysts.length > 0 && (
              <div>
                <div class="flex items-center justify-between mb-3">
                  <div class="text-sm text-[#64748B]">Analysts Covering {stock.symbol}</div>
                  <div class="flex items-center gap-2 text-xs">
                    <span class="text-[#64748B]">Sort by:</span>
                    <button id="sort-accuracy" class="analyst-sort-btn px-2 py-1 rounded bg-[#22D3EE]/20 text-[#22D3EE] font-medium">Accuracy</button>
                    <button id="sort-date" class="analyst-sort-btn px-2 py-1 rounded text-[#64748B] hover:text-slate-200 transition">Date</button>
                  </div>
                </div>
                <div id="analysts-list" class="space-y-2">
                  {enhancedAnalysts.map(analyst => {
                    const ratingColors = analyst.rating ? getRatingColor(analyst.rating) : null;
                    return (
                      <div
                        class="analyst-row flex items-center justify-between bg-[#080A0F] rounded-lg px-4 py-3"
                        data-hitrate={analyst.hitRate}
                        data-date={analyst.ratingDate || ''}
                        data-percentile={analyst.percentile}
                        data-pricetarget={analyst.priceTarget || ''}
                      >
                        <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3">
                          <span class="text-slate-200 font-medium">{analyst.firm}</span>
                          <div class="flex items-center gap-2">
                            {analyst.rating && ratingColors && (
                              <span class={`px-2 py-0.5 rounded text-xs font-medium ${ratingColors.bg} ${ratingColors.text}`}>
                                {analyst.rating}
                              </span>
                            )}
                            {analyst.ratingDate && (
                              <span class="analyst-date text-[#64748B] text-xs">
                                {new Date(analyst.ratingDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                              </span>
                            )}
                          </div>
                        </div>
                        <div class="flex items-center gap-4">
                          {analyst.priceTarget && (
                            <div class="text-right">
                              <span class="text-slate-200 font-semibold">${analyst.priceTarget.toFixed(0)}</span>
                              {stock.price && (
                                <span class={`ml-1 text-xs ${analyst.priceTarget > stock.price ? 'text-emerald-400' : 'text-red-400'}`}>
                                  ({analyst.priceTarget > stock.price ? '+' : ''}{(((analyst.priceTarget - stock.price) / stock.price) * 100).toFixed(0)}%)
                                </span>
                              )}
                            </div>
                          )}
                          <span class={`font-bold ${analyst.percentile >= 75 ? 'text-emerald-400' : analyst.percentile >= 25 ? 'text-amber-400' : 'text-red-400'}`}>
                            {analyst.hitRate}%
                          </span>
                          <span class="text-[#64748B] text-sm whitespace-nowrap">
                            {analyst.percentile >= 50 ? `Top ${100 - analyst.percentile}%` : `Bottom ${analyst.percentile}%`}
                          </span>
                        </div>
                      </div>
                    );
                  })}
                </div>
                <div class="mt-3 text-xs text-[#64748B]">
                  Hit rate = % of calls where the stock moved in the predicted direction
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Related Stocks (Free) -->
      {relatedStocks.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-bold mb-4 text-slate-100">Similar High-Quality Stocks</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {relatedStocks.map(related => {
              const relatedColors = getGradeColor(related.grade);
              return (
                <a href={`/stock/${related.symbol.toLowerCase()}`}
                   class="bg-[#161B24] border border-[rgba(255,255,255,0.06)] rounded-xl p-4 hover:border-[#22D3EE33] transition">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <h3 class="font-bold text-slate-100">{related.symbol}</h3>
                      <p class="text-[#64748B] text-sm truncate max-w-[150px]">{related.name}</p>
                    </div>
                    <div class={`px-2 py-1 rounded-full ${relatedColors.bg} ${relatedColors.text} text-sm font-bold`}>
                      {related.compassScore}
                    </div>
                  </div>
                  <div class="flex justify-between items-end">
                    <div class="text-lg font-semibold text-slate-100">{formatPrice(related.price)}</div>
                    <div class={`text-sm font-semibold ${relatedColors.text}`}>Grade {related.grade}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}

      <!-- Disclaimer -->
      <div class="bg-amber-900/20 border border-amber-700/30 rounded-xl p-6">
        <h3 class="font-semibold text-amber-400 mb-2">Important Disclaimer</h3>
        <p class="text-sm text-amber-200/80">
          The Compass Score is for educational purposes only and does not constitute financial advice.
          Past performance does not guarantee future results. Always do your own research and consider
          consulting a financial advisor before making investment decisions.
        </p>
      </div>
    </div>
  </section>

  <!-- Upgrade Modal -->
  <UpgradeModal />

  <script>
    import { loadSession, hasFeature } from '../../lib/subscription';
    import { authFetch } from '../../lib/authFetch';

    document.addEventListener('DOMContentLoaded', async () => {
      // Load the user session (populates window.__compassUser)
      const user = await loadSession();

      // Check if user has premium access
      const isPremium = hasFeature('score_breakdown');

      if (isPremium) {
        // Remove blur and overlays for premium users
        document.querySelectorAll('.premium-section').forEach(section => {
          const content = section.querySelector('.premium-content');
          const overlay = section.querySelector('.premium-overlay');
          const badge = section.querySelector('.premium-badge');

          if (content) {
            content.classList.remove('blur-sm', 'pointer-events-none', 'select-none');
          }
          if (overlay) {
            overlay.remove();
          }
          if (badge) {
            badge.remove();
          }
        });

        // Hydrate premium fields from the API
        const symbol = window.location.pathname.split('/stock/')[1]?.replace(/\/$/, '').toUpperCase();
        if (symbol) {
          try {
            const res = await authFetch(`/api/stocks/premium?symbol=${symbol}`);
            if (res.ok) {
              const premium = await res.json();
              // Premium data is now available — hydrate any data-premium-slot elements
              // This is a placeholder for v1.D.11 where we add per-slot hydration logic.
              // For now, the SSG-rendered N/A values get replaced by JS as the API comes online.
              if (premium) {
                (window as any).__premiumData = premium;
              }
            }
          } catch {
            // Silently fail — user sees the SSG version with N/A values
          }
        }
      }

      // Factor card clicks - toggle detail panel
      const factorCards = document.querySelectorAll('.factor-card');
      factorCards.forEach(card => {
        card.addEventListener('click', () => {
          const wrapper = card.closest('.factor-wrapper');
          const detail = wrapper?.querySelector('.factor-detail');
          if (detail) {
            // Close all other open details
            document.querySelectorAll('.factor-detail').forEach(d => {
              if (d !== detail) d.classList.add('hidden');
            });
            // Toggle this detail
            detail.classList.toggle('hidden');
          }
        });
      });

      // Metric card clicks - toggle detail panel (for Valuation, Technical, Financial Health)
      const metricCards = document.querySelectorAll('.metric-card');
      metricCards.forEach(card => {
        card.addEventListener('click', () => {
          const wrapper = card.closest('.metric-wrapper');
          const detail = wrapper?.querySelector('.metric-detail');
          if (detail) {
            // Close all other open metric details
            document.querySelectorAll('.metric-detail').forEach(d => {
              if (d !== detail) d.classList.add('hidden');
            });
            // Toggle this detail
            detail.classList.toggle('hidden');
          }
        });
      });

      // Handle unlock button clicks
      const unlockButtons = document.querySelectorAll('.unlock-btn');
      unlockButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          (window as any).showUpgradeModal();
        });
      });

      // Analyst sorting functionality
      const sortAccuracyBtn = document.getElementById('sort-accuracy');
      const sortDateBtn = document.getElementById('sort-date');
      const analystsList = document.getElementById('analysts-list');

      function sortAnalysts(by: 'accuracy' | 'date') {
        if (!analystsList) return;

        const rows = Array.from(analystsList.querySelectorAll('.analyst-row'));
        rows.sort((a, b) => {
          if (by === 'accuracy') {
            const aRate = parseFloat(a.getAttribute('data-hitrate') || '0');
            const bRate = parseFloat(b.getAttribute('data-hitrate') || '0');
            return bRate - aRate;
          } else {
            const aDate = a.getAttribute('data-date') || '';
            const bDate = b.getAttribute('data-date') || '';
            // Dates with values come first, then sort by date descending
            if (aDate && !bDate) return -1;
            if (!aDate && bDate) return 1;
            return bDate.localeCompare(aDate);
          }
        });

        rows.forEach(row => analystsList.appendChild(row));

        // Update button styles
        if (sortAccuracyBtn && sortDateBtn) {
          if (by === 'accuracy') {
            sortAccuracyBtn.classList.add('bg-[#22D3EE]/20', 'text-[#22D3EE]');
            sortAccuracyBtn.classList.remove('text-[#64748B]');
            sortDateBtn.classList.remove('bg-[#22D3EE]/20', 'text-[#22D3EE]');
            sortDateBtn.classList.add('text-[#64748B]');
          } else {
            sortDateBtn.classList.add('bg-[#22D3EE]/20', 'text-[#22D3EE]');
            sortDateBtn.classList.remove('text-[#64748B]');
            sortAccuracyBtn.classList.remove('bg-[#22D3EE]/20', 'text-[#22D3EE]');
            sortAccuracyBtn.classList.add('text-[#64748B]');
          }
        }
      }

      sortAccuracyBtn?.addEventListener('click', () => sortAnalysts('accuracy'));
      sortDateBtn?.addEventListener('click', () => sortAnalysts('date'));
    });
  </script>
</Layout>
